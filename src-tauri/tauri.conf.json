{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "galdr",
  "version": "0.2.1",
  "identifier": "com.ellio.galdr",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "python src-tauri/windows/nsniuniuskin/prepare-nsis.py && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GALDR",
        "width": 1100,
        "height": 750,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": [
          "galdr"
        ],
        "name": "Galdr Project",
        "description": "Galdr video editor project file"
      }
    ],
    "licenseFile": "windows/LICENSE.txt",
    "resources": [
      "binaries/*"
    ],
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser",
        "template": "./windows/nsniuniuskin/installer.nsi",
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": []
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ellipog/galdr/releases/latest/download/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxQzUwRTc0OTZFMTJDMTcKUldRWExPR1dkQTdGNFJ5dlgzaERKWDFqUjZEVnBObFowMjB6YUdWdVNGMDIvUG1xZFB2bmRTaFoK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}