<?xml version="1.0" encoding="utf-8"?>
<Windows>
  <VerticalLayout name="configpage">
    <!-- Header: logo + title block -->
    <VerticalLayout height="160" padding="30,40,30,0">
      <HorizontalLayout height="80">
        <Control width="80" height="80" bkimage="file='form\logo.png'" />
        <Control width="15" />
        <VerticalLayout>
          <Label text="GALDR" font="2" textcolor="#FFC8C8C8" height="36" />
          <Label name="versionLabel" text="v0.2.1" font="6" textcolor="#FF6A6A6A" height="20" />
          <Label text="MEDIA CONVERTER FOR EVERYONE" font="3" textcolor="#FFC8C8C8" height="24" />
        </VerticalLayout>
      </HorizontalLayout>
    </VerticalLayout>

    <!-- Expandable install-location + features panel (hidden until CUSTOMIZE) -->
    <VerticalLayout name="moreconfiginfo" visible="false" padding="30,0,30,0" height="170">
      <Label text="INSTALL LOCATION:" font="6" textcolor="#FF6A6A6A" height="18" />
      <HorizontalLayout height="32">
        <RichEdit name="editDir" height="28" font="4" textcolor="#FFC8C8C8" padding="5,0,0,0" bkimage="public\edit\edit0.png" />
        <Control width="8" />
        <Button name="btnSelectDir" width="70" height="28" text="BROWSE" font="6" textcolor="#FFC8C8C8" normalimage="form\btn_secondary_normal.png" hotimage="form\btn_secondary_hover.png" pushedimage="form\btn_secondary_pressed.png" />
      </HorizontalLayout>
      <HorizontalLayout height="18">
        <Label name="space_required" font="6" textcolor="#FF6A6A6A" width="150" />
        <Control width="10" />
        <Label name="local_space" font="6" textcolor="#FF6A6A6A" width="150" />
        <Control />
      </HorizontalLayout>
      <Control height="4" />
      <Label text="FEATURES:" font="6" textcolor="#FF6A6A6A" height="18" />
      <CheckBox name="chkDiscord" font="5" height="22" align="left" valign="center" textpadding="22,0,0,0" text="DISCORD RICH PRESENCE" textcolor="#FFC8C8C8" selected="true" normalimage="file='public\checkbox\chk_normal.png' dest='0,3,16,16'" normalhotimage="file='public\checkbox\chk_hover.png' dest='0,3,16,16'" selectedimage="file='public\checkbox\chk_checked.png' dest='0,3,16,16'" selectedhotimage="file='public\checkbox\chk_checked.png' dest='0,3,16,16'" disabledimage="file='public\checkbox\chk_disabled.png' dest='0,3,16,16'" />
      <CheckBox name="chkCrt" font="5" height="22" align="left" valign="center" textpadding="22,0,0,0" text="CRT SCAN-LINE EFFECT" textcolor="#FFC8C8C8" selected="false" normalimage="file='public\checkbox\chk_normal.png' dest='0,3,16,16'" normalhotimage="file='public\checkbox\chk_hover.png' dest='0,3,16,16'" selectedimage="file='public\checkbox\chk_checked.png' dest='0,3,16,16'" selectedhotimage="file='public\checkbox\chk_checked.png' dest='0,3,16,16'" disabledimage="file='public\checkbox\chk_disabled.png' dest='0,3,16,16'" />
      <CheckBox name="chkRune" font="5" height="22" align="left" valign="center" textpadding="22,0,0,0" text="RUNE IN TITLEBAR" textcolor="#FFC8C8C8" selected="true" normalimage="file='public\checkbox\chk_normal.png' dest='0,3,16,16'" normalhotimage="file='public\checkbox\chk_hover.png' dest='0,3,16,16'" selectedimage="file='public\checkbox\chk_checked.png' dest='0,3,16,16'" selectedhotimage="file='public\checkbox\chk_checked.png' dest='0,3,16,16'" disabledimage="file='public\checkbox\chk_disabled.png' dest='0,3,16,16'" />
      <CheckBox name="chkTransitions" font="5" height="22" align="left" valign="center" textpadding="22,0,0,0" text="PAGE TRANSITIONS" textcolor="#FFC8C8C8" selected="true" normalimage="file='public\checkbox\chk_normal.png' dest='0,3,16,16'" normalhotimage="file='public\checkbox\chk_hover.png' dest='0,3,16,16'" selectedimage="file='public\checkbox\chk_checked.png' dest='0,3,16,16'" selectedhotimage="file='public\checkbox\chk_checked.png' dest='0,3,16,16'" disabledimage="file='public\checkbox\chk_disabled.png' dest='0,3,16,16'" />
    </VerticalLayout>

    <!-- Flexible spacer pushes the action bar to the bottom -->
    <Control />

    <!-- Customize row: label beside the button -->
    <HorizontalLayout height="30" padding="30,0,30,0">
      <Label text="CONFIGURE INSTALL OPTIONS" font="6" textcolor="#FF6A6A6A" height="30" valign="center" />
      <Control width="8" />
      <Button name="btnShowMore" text="CUSTOMIZE" font="6" textcolor="#FFC8C8C8" height="28" width="100" normalimage="form\btn_secondary_normal.png" hotimage="form\btn_secondary_hover.png" pushedimage="form\btn_secondary_pressed.png" />
      <Button name="btnHideMore" text="HIDE" font="6" textcolor="#FFC8C8C8" height="28" width="100" visible="false" normalimage="form\btn_secondary_normal.png" hotimage="form\btn_secondary_hover.png" pushedimage="form\btn_secondary_pressed.png" />
    </HorizontalLayout>

    <!-- License acceptance row: checkbox + license name label + VIEW button -->
    <HorizontalLayout height="24" padding="30,4,30,4">
      <CheckBox name="chkAgree" width="18" height="18" text="" textcolor="#FF6A6A6A" selected="false" align="left" valign="center" normalimage="file='public\checkbox\chk_normal.png' dest='0,1,16,16'" normalhotimage="file='public\checkbox\chk_hover.png' dest='0,1,16,16'" selectedimage="file='public\checkbox\chk_checked.png' dest='0,1,16,16'" selectedhotimage="file='public\checkbox\chk_checked.png' dest='0,1,16,16'" disabledimage="file='public\checkbox\chk_disabled.png' dest='0,1,16,16'" />
      <Control width="8" />
      <Label text="I ACCEPT THE" font="6" textcolor="#FF6A6A6A" height="24" valign="center" />
      <Control width="4" />
      <Label text="GNU GPL v3" font="6" textcolor="#FFC8C8C8" height="24" valign="center" />
      <Control width="6" />
      <Button name="btnAgreement" font="6" text="VIEW" textcolor="#FFC8C8C8" height="22" width="50" normalimage="form\btn_secondary_normal.png" hotimage="form\btn_secondary_hover.png" pushedimage="form\btn_secondary_pressed.png" />
      <Control />
    </HorizontalLayout>

    <!-- Primary INSTALL button -->
    <Button name="btnInstall" padding="30,5,30,15" width="140" height="40" text="INSTALL" font="1" textcolor="#FFC8C8C8" normalimage="form\btn_primary_normal.png" hotimage="form\btn_primary_hover.png" pushedimage="form\btn_primary_pressed.png" />
  </VerticalLayout>
</Windows>
